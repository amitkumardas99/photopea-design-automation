{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "types": ["node", "@playwright/test"],

    "baseUrl": "https://www.photopea.com",
    "paths": {
      "@pages/*": ["pages/*"],
      "@utils/*": ["utils/*"],
      "@tests/*": ["tests/*"],
      "@data/*": ["test-data/*"]
    },

    "resolveJsonModule": true,
    "esModuleInterop": true,
    "moduleResolution": "node",

    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "outDir": "dist"
  },
  "include": [
    "tests",
    "pages",
    "utils",
    "test-data",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}